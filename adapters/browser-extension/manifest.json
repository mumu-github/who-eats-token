{
  "manifest_version": 3,
  "name": "Who Eats Token Adapter",
  "version": "0.1.0",
  "description": "Reports supported web-tool HUD avoidance hints and usage events to the local Who Eats Token desktop app.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:17667/*",
    "http://localhost:17667/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Who Eats Token Adapter"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:8648/*",
        "http://localhost:8648/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
